<!DOCTYPE html>
<html lang="en">
<head>
    <title>Flashcards</title>
    <link rel="icon" type="image/png" href="/deployer/mottzi.png">
    <link rel="stylesheet" href="/mistexamples.css">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
</head>
<body>
    <main class="container">
        <a href="/MistExamples" class="back-link">← Back to Examples</a>
        <header class="mb-4">
            <h1>Flashcards</h1>
            <p class="desc">Interactive flashcards with real-time state syncing and persistence.</p>
        </header>
        #extend("FlashcardExample/FlashcardCreateComponent")
        <div class="flashcard-grid" mist-container="FlashcardComponent">
            #for(context in contexts):
                #extend("FlashcardExample/FlashcardComponent")
            #endfor
        </div>
    </main>
    <script src="/morphdom.js"></script>
    <script src="/mist.js"></script>
</body>
</html>