<div class="flashcard #if(state.isFlipped): flipped #endif" mist-component="FlashcardComponent" mist-id="#(context.flashcardfrontmodel.id)" onclick="if(!event.target.closest('button')) this.querySelector('.flip-trigger').click()">
    <button class="flip-trigger flashcard-flip-trigger" mist-action="flip"></button>
     <div class="flashcard-inner">
...
            <span class="flashcard-language-label">🇺🇸</span>
            <div class="flashcard-text">#(context.flashcardfrontmodel.text)</div>
            <div class="flashcard-actions">
                <button mist-action="ShuffleTextAction">Shuffle</button>
                <button mist-action="delete" class="btn-danger">Delete</button>
            </div>
        </div>
        <div class="flashcard-back">
            <span class="flashcard-language-label">🇪🇸</span>
            <div class="flashcard-text">#(context.flashcardbackmodel.text)</div>
        </div>
    </div>
</div>
