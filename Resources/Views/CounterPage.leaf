<!DOCTYPE html>
<html lang="en">
<head>
    <meta name="description" content="Mist with Leaf">
    <link rel="stylesheet" href="/mistexamples.css">
    <title>Counter Example</title>
</head>
<body>
    <main class="container">
        <a href="/MistExamples" class="back-link">← Back to Examples</a>
        
        <header class="mb-4">
            <h1>Counter Example</h1>
            <p class="desc">A global counter demonstrating real-time manual state updates across all connected clients.</p>
        </header>
        
        <!-- Mist allows you to extend the inline component by its name -->
        #extend("CounterComponent")
        
    </main>
    
    <script src="/morphdom.js"></script>
    <script src="/mist.js"></script>
</body>
</html>