<!DOCTYPE html>
<html lang="en">
<head>
    <title>Team directory · #(division)</title>
    <link rel="icon" type="image/png" href="/deployer/mottzi.png">
    <link rel="stylesheet" href="/mistexamples.css">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
</head>
<body>
    <main class="container">
        <a href="/MistExamples" class="back-link">← Back to Examples</a>
        <header class="mb-4">
            <span class="badge" style="margin-bottom: 0.75rem;">InstanceComponent</span>
            <h1 style="margin-top: 0;">Team directory</h1>
            <p class="desc">
                Multi-model <code class="inline-code">InstanceComponent</code>: one card per <code class="inline-code">User</code> row, paired <code class="inline-code">Profile</code> by shared UUID.
                Division <strong>#(division)</strong> — try <a href="/teamprofile/europe">europe</a> or <a href="/teamprofile/east-coast">east-coast</a>.
            </p>
        </header>
        <div class="profile-grid" mist-container="ProfileComponent-#(division)" mist-ssr="true">
            #for(context in contexts):
                #extend("TeamProfileExample/ProfileComponent")
            #endfor
        </div>
    </main>
    <script src="/morphdom.js"></script>
    <script src="/mist.js"></script>
</body>
</html>
